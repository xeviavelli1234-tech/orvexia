    "db:sync-eci-frigorificos-prices": "tsx scripts/sync-eci-frigorificos-prices.ts",
    "db:sync-eci-lavavajillas-prices": "tsx scripts/sync-eci-lavavajillas-prices.ts",
    "db:import-awin-feed": "tsx scripts/import-awin-feed.ts",
    "db:backfill-specs": "tsx --env-file=.env.local scripts/backfill-specs.ts",
    "db:scrape-images-lg": "tsx scripts/scrape-images-lg.ts",
    "build": "prisma generate && PRISMA_SCHEMA_DISABLE_ADVISORY_LOCK=1 prisma migrate deploy && node --max-old-space-size=12288 node_modules/next/dist/bin/next build",
