generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                       String    @id @default(cuid())
  name                     String
  email                    String    @unique
  password                 String?
  googleId                 String?   @unique
  emailVerified            Boolean   @default(false)
  verificationToken        String?   @unique
  verificationTokenExpires DateTime?
  resetPasswordToken       String?   @unique
  resetPasswordExpires     DateTime?
  avatarColor              String    @default("#2563EB")
  avatarEmoji              String?
  avatarUrl                String?   @db.Text
  bio                      String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  savedProducts SavedProduct[]
  priceAlerts   PriceAlert[]
  communityPosts    CommunityPost[]
  communityComments CommunityComment[]
  communityVotes    CommunityVote[]
  reviews           Review[]
  sellerAccount     SellerAccount?
}

// в”Җв”Җв”Җ CategorГӯas disponibles в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
enum Category {
  TELEVISORES
  LAVADORAS
  FRIGORIFICOS
  LAVAVAJILLAS
  SECADORAS
  HORNOS
  MICROONDAS
  ASPIRADORAS
  CAFETERAS
  AIRES_ACONDICIONADOS
  OTROS
}

// в”Җв”Җв”Җ Producto в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// Representa un electrodomГ©stico genГ©rico (independiente de tienda o precio).
// Un mismo producto puede tener ofertas en varias tiendas.
model Product {
  id          String    @id @default(cuid())
  slug        String    @unique           // ej: "samsung-galaxy-qled-55-2024"
  name        String                      // ej: "Samsung QLED 55\" 4K Q80C"
  category    Category
  brand       String                      // ej: "Samsung"
  model       String                      // ej: "QE55Q80CATXXC"
  image       String?                     // URL de imagen principal
  images      String[]                    // galerГӯa de imГЎgenes
  description String?
  rating      Float?                      // ej: 4.4
  reviewCount Int?                        // ej: 4471
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  offers        Offer[]
  priceHistory  PriceHistory[]
  buySignals    BuySignal[]
  savedBy       SavedProduct[]
  priceAlerts   PriceAlert[]
  communityPosts CommunityPost[]
  reviews       Review[]

  @@index([category])
  @@index([brand])
  @@index([slug])
}

// в”Җв”Җв”Җ Oferta por tienda в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// Precio de un producto en una tienda concreta.
// Un producto вҶ’ muchas ofertas (una por tienda).
model Offer {
  id              String   @id @default(cuid())
  productId       String
  store           String                   // ej: "Amazon", "MediaMarkt", "PcComponentes"
  priceCurrent    Float                    // precio actual en euros
  priceOld        Float?                   // precio anterior (para mostrar tachado)
  discountPercent Int?                     // % de descuento calculado
  externalUrl     String                   // enlace directo al producto en la tienda
  inStock         Boolean  @default(true)
  updatedAt       DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, store])             // un producto solo tiene una oferta por tienda
  @@index([productId])
  @@index([store])
  @@index([priceCurrent])
}

// в”Җв”Җв”Җ Historial de precios в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// Registro histГіrico de cada cambio de precio por producto y tienda.
// Permite mostrar "precio mГӯnimo histГіrico" y grГЎficas de evoluciГіn.
model PriceHistory {
  id        String   @id @default(cuid())
  productId String
  store     String
  price     Float
  recordedAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([productId, store])
  @@index([recordedAt])
}

// в”Җв”Җв”Җ Producto guardado в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
model SavedProduct {
  id        String   @id @default(cuid())
  userId    String
  productId String
  savedAt   DateTime @default(now())
  notifyOnDiscount    Boolean   @default(false)
  discountAlertSentAt DateTime?
  savedPriceCurrent   Float?
  betterDealAlertSentAt DateTime?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([notifyOnDiscount])
}

// в”Җв”Җв”Җ Alerta de precio в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
model PriceAlert {
  id          String    @id @default(cuid())
  userId      String
  productId   String
  store       String
  targetPrice Float
  triggered   Boolean   @default(false)
  triggeredAt DateTime?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([productId])
}

// в”Җв”Җв”Җ SeГұal de Compra в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
model BuySignal {
  id           String   @id @default(cuid())
  productId    String
  store        String

  score        Int      // 0-100
  label        String   // "Compra ahora" | "Buen momento" | etc.

  priceScore   Int      // 0-40
  trendScore   Int      // 0-25
  storeScore   Int      // 0-20
  dealScore    Int      // 0-15

  priceMin90d  Float
  priceMax90d  Float
  priceAvg90d  Float
  trendSlope   Float    // вӮ¬/dГӯa
  isFakeDeal   Boolean

  calculatedAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, store])
  @@index([productId])
  @@index([score])
}

model StoreReputation {
  id               String   @id @default(cuid())
  store            String   @unique
  manipulationRate Float    @default(0)
  fakeDealCount    Int      @default(0)
  totalDeals       Int      @default(0)
  updatedAt        DateTime @updatedAt
}

// ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ Comunidad ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬

enum CommunityPostType {
  DISCUSION
  PREGUNTA
  CHOLLO
  CONSEJO
}

model CommunityPost {
  id        String            @id @default(cuid())
  userId    String
  productId String?
  title     String
  content   String            @db.Text
  type      CommunityPostType @default(DISCUSION)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  comments CommunityComment[]
  votes    CommunityVote[]

  @@index([type])
  @@index([createdAt])
}

model CommunityComment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  content   String   @db.Text
  createdAt DateTime @default(now())

  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([userId])
}

model CommunityVote {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  value     Int      @default(1)
  createdAt DateTime @default(now())

  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

// в”Җв”Җв”Җ ReseГұas в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
model Review {
  id        String   @id @default(cuid())
  productId String
  userId    String
  rating    Int      // 1-5
  title     String?
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([productId, userId])
  @@index([productId])
  @@index([userId])
}

// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
//  MГ“DULO REPRICER (sellers B2B) вҖ” independiente del comparador B2C
// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ

enum SellerPlan {
  TRIAL
  PRO
}

enum RepriceStrategy {
  BUYBOX // bajar por debajo del competidor mГЎs barato
  MATCH // igualar al competidor
  FIXED // precio fijo (ignora competencia)
  MARGIN // como BUYBOX pero con suelo de beneficio
}

enum UndercutType {
  AMOUNT // restar importe fijo (ej. 0,01 вӮ¬)
  PERCENT // restar porcentaje (ej. 2 %)
}

enum NoCompetitionMode {
  MAX // sin competencia вҶ’ subir al mГЎximo
  HOLD // sin competencia вҶ’ mantener precio
  STEP_UP // sin competencia вҶ’ subir gradualmente hacia el mГЎximo
}

enum FulfillmentFilter {
  ANY // considerar todas las ofertas
  FBA // solo competidores con LogГӯstica de Amazon
  FBM // solo competidores que envГӯan ellos mismos
}

enum BuyBoxStatus {
  UNKNOWN
  WON // tenemos la Buy Box
  LOST // la tiene otro vendedor
}

model SellerAccount {
  id              String     @id @default(cuid())
  userId          String     @unique
  amazonSellerId  String     @unique
  marketplaceId   String     @default("A1RKKUPIHCS9HS")
  refreshToken    String     @db.Text
  spApiEnv        String     @default("sandbox")

  plan                 SellerPlan @default(TRIAL)
  trialEndsAt          DateTime?
  intervalSeconds      Int        @default(900)
  stripeCustomerId     String?    @unique
  stripeSubscriptionId String?    @unique

  active          Boolean    @default(true)
  lastSyncAt      DateTime?
  lastRunAt       DateTime?
  lockedAt        DateTime?                            // lock de ciclo (evita solapamientos)

  // в”Җв”Җ Estrategia por defecto de la cuenta (productos con useAccountDefaults) в”Җв”Җ
  defaultStrategy      RepriceStrategy   @default(BUYBOX)
  defaultUndercutType  UndercutType      @default(AMOUNT)
  defaultUndercutValue Float             @default(0.01)
  defaultNoCompetition NoCompetitionMode @default(MAX)
  defaultStepUpType    UndercutType      @default(AMOUNT)
  defaultStepUpValue   Float             @default(0.05)

  // в”Җв”Җ ProgramaciГіn horaria, simulaciГіn y throttling в”Җв”Җ
  scheduleEnabled  Boolean @default(false)
  scheduleStartHour Int    @default(0)   // hora local Europe/Madrid (0-23)
  scheduleEndHour   Int    @default(24)  // exclusivo (24 = fin de dГӯa)
  dryRun           Boolean @default(false) // calcula pero NO aplica en Amazon
  patchDelayMs     Int     @default(0)     // retardo entre PATCHes (anti QuotaExceeded)
  autoSyncHours    Int     @default(0)     // sincroniza catГЎlogo cada N h (0 = manual)

  // в”Җв”Җ Alertas por email в”Җв”Җ
  alertsEnabled     Boolean @default(true)
  alertEmail        String?                 // destino (vacГӯo = email de la cuenta)
  alertOnBuyBoxLost Boolean @default(true)  // avisar al perder la Buy Box
  alertOnPriceFloor Boolean @default(true)  // avisar al tocar el precio mГӯnimo
  alertOnError      Boolean @default(true)  // avisar ante errores de reprecio
  lastAlertAt       DateTime?               // cooldown anti-spam de correos

  // в”Җв”Җ Datos fiscales del cliente (para la factura) в”Җв”Җ
  billingName     String @default("") // razГіn social / nombre fiscal
  billingTaxId    String @default("") // NIF / CIF / VAT
  billingAddress  String @default("") // direcciГіn fiscal
  billingCountry  String @default("ES")

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  listings SellerListing[]
  runs     RepricingRun[]

  @@index([active, lastRunAt])
}

model SellerListing {
  id              String   @id @default(cuid())
  sellerAccountId String

  asin            String
  sku             String
  title           String
  imageUrl        String?
  productType     String?                            // SP-API productType (TELEVISION, etc), required for PATCH

  priceCurrent    Float
  priceMin        Float?
  priceMax        Float?
  currency        String   @default("EUR")

  repricingEnabled Boolean  @default(false)
  lastRepricedAt   DateTime?
  tags             String   @default("") // etiquetas/grupos, separadas por comas

  // в”Җв”Җ Estrategia de reprecio в”Җв”Җ
  strategy      RepriceStrategy   @default(BUYBOX)
  undercutType  UndercutType      @default(AMOUNT)
  undercutValue Float             @default(0.01)
  fixedPrice    Float?            // estrategia FIXED
  cost          Float?            // coste del producto (estrategia MARGIN)
  shippingCost  Float?            // envГӯo / logГӯstica propia por ud (вӮ¬)
  fbaFee        Float?            // tarifa fija FBA / gestiГіn por ud (вӮ¬)
  vatRate       Float?            @default(21) // % IVA del PVP (ES 21)
  feePercent    Float?            @default(15) // % comisiГіn Amazon
  targetMargin  Float?            @default(10) // % margen objetivo (MARGIN)
  noCompetition NoCompetitionMode @default(MAX)
  stepUpType    UndercutType      @default(AMOUNT) // STEP_UP: paso вӮ¬ o %
  stepUpValue   Float             @default(0.05)   // STEP_UP: tamaГұo del paso

  // в”Җв”Җ Filtros de competencia в”Җв”Җ
  useAccountDefaults Boolean           @default(false) // hereda estrategia de la cuenta
  ignoreAmazon       Boolean           @default(true)  // ignorar al propio Amazon (retail)
  fulfillmentFilter  FulfillmentFilter @default(ANY)
  minSellerRating    Float?            // ignorar vendedores por debajo (0-5)
  excludeSellers     String            @default("") // seller IDs a ignorar (lista negra)
  onlySellers        String            @default("") // si hay: solo estos (lista blanca)

  // в”Җв”Җ Estado Buy Box в”Җв”Җ
  buyBoxStatus  BuyBoxStatus @default(UNKNOWN)
  buyBoxPrice   Float?
  buyBoxAt      DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  sellerAccount SellerAccount    @relation(fields: [sellerAccountId], references: [id], onDelete: Cascade)
  events        RepricingEvent[]

  @@unique([sellerAccountId, sku])
  @@index([sellerAccountId, repricingEnabled])
}

model RepricingRun {
  id              String    @id @default(cuid())
  sellerAccountId String
  startedAt       DateTime  @default(now())
  finishedAt      DateTime?

  listingsProcessed Int     @default(0)
  listingsRepriced  Int     @default(0)
  errors            Int     @default(0)
  errorMessage      String? @db.Text

  sellerAccount SellerAccount    @relation(fields: [sellerAccountId], references: [id], onDelete: Cascade)
  events        RepricingEvent[]

  @@index([sellerAccountId, startedAt])
}

model RepricingEvent {
  id              String   @id @default(cuid())
  runId           String
  listingId       String

  priceBefore     Float
  priceAfter      Float
  competitorPrice Float?
  reason          String
  success         Boolean  @default(true)
  simulated       Boolean  @default(false) // dry-run: calculado pero no aplicado
  buyBox          BuyBoxStatus @default(UNKNOWN) // estado Buy Box en ese ciclo
  errorMessage    String?  @db.Text

  createdAt       DateTime @default(now())

  run     RepricingRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  listing SellerListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, createdAt])
  @@index([runId])
}

