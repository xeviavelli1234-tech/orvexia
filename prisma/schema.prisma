generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                       String    @id @default(cuid())
  name                     String
  email                    String    @unique
  password                 String?
  googleId                 String?   @unique
  emailVerified            Boolean   @default(false)
  verificationToken        String?   @unique
  verificationTokenExpires DateTime?
  resetPasswordToken       String?   @unique
  resetPasswordExpires     DateTime?
  totpSecret               String? // base32 cifrado (AES-GCM)
  totpEnabled              Boolean   @default(false)
  totpRecovery             String?   @db.Text // JSON: hashes bcrypt de códigos
  avatarColor              String    @default("#2563EB")
  avatarEmoji              String?
  avatarUrl                String?   @db.Text
  bio                      String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  savedProducts     SavedProduct[]
  priceAlerts       PriceAlert[]
  communityPosts    CommunityPost[]
  communityComments CommunityComment[]
  communityVotes    CommunityVote[]
  reviews           Review[]
  sellerAccount     SellerAccount?
  passkeys          Passkey[]
  magicLinks        MagicLink[]
  loginAttempts     LoginAttempt[]
  trustedLocations  TrustedLocation[]
  affiliateClicks   AffiliateClickEvent[]
}

// ─── Seguridad: passkeys, magic links, intentos de inicio, ubicaciones ──────
model Passkey {
  id           String    @id @default(cuid())
  userId       String
  credentialId String    @unique // base64url del id de la credencial
  publicKey    String    @db.Text // base64url de la public key
  counter      Int       @default(0)
  transports   String    @default("") // "internal,hybrid" etc, CSV
  deviceType   String    @default("singleDevice") // singleDevice | multiDevice
  backedUp     Boolean   @default(false)
  name         String    @default("Mi llave") // alias para el usuario
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model MagicLink {
  id          String    @id @default(cuid())
  userId      String
  tokenHash   String    @unique // bcrypt del token enviado (no se guarda en claro)
  expiresAt   DateTime
  usedAt      DateTime?
  ipAtRequest String?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model LoginAttempt {
  id        String   @id @default(cuid())
  userId    String?
  email     String?
  ip        String?
  country   String?
  userAgent String?  @db.Text
  method    String   @default("password") // password | passkey | magic | totp_verify | google
  success   Boolean
  reason    String? // "bad_password" | "totp_failed" | "new_location" | "ok"
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([email, createdAt])
}

model TrustedLocation {
  id         String   @id @default(cuid())
  userId     String
  ip         String // recordamos la /24 (IPv4) o /64 (IPv6) para tolerar cambios menores
  country    String?
  label      String   @default("Sin etiqueta") // p. ej. "Casa", "Oficina"
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ip])
  @@index([userId])
}

model WebAuthnChallenge {
  id        String   @id @default(cuid())
  userId    String? // null durante el registro guest (no soportado aquí)
  challenge String   @unique
  type      String // "registration" | "authentication"
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([challenge, expiresAt])
}

// ─── Categorías disponibles ───────────────────────────────────────────────────
enum Category {
  TELEVISORES
  LAVADORAS
  FRIGORIFICOS
  LAVAVAJILLAS
  SECADORAS
  HORNOS
  MICROONDAS
  ASPIRADORAS
  CAFETERAS
  AIRES_ACONDICIONADOS
  OTROS
}

// ─── Producto ─────────────────────────────────────────────────────────────────
// Representa un electrodoméstico genérico (independiente de tienda o precio).
// Un mismo producto puede tener ofertas en varias tiendas.
model Product {
  id          String   @id @default(cuid())
  slug        String   @unique // ej: "samsung-galaxy-qled-55-2024"
  name        String // ej: "Samsung QLED 55\" 4K Q80C"
  category    Category
  brand       String // ej: "Samsung"
  model       String // ej: "QE55Q80CATXXC"
  image       String? // URL de imagen principal
  images      String[] // galería de imágenes
  description String?
  rating      Float? // ej: 4.4
  reviewCount Int? // ej: 4471
  // Specs estructuradas extraídas de name+description por lib/specs/extractor.ts
  // Formato JSON flexible: { sizeInches: 55, tech: "OLED", energyClass: "A++", ... }
  specs       Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  offers          Offer[]
  priceHistory    PriceHistory[]
  buySignals      BuySignal[]
  savedBy         SavedProduct[]
  priceAlerts     PriceAlert[]
  communityPosts  CommunityPost[]
  reviews         Review[]
  affiliateClicks AffiliateClickEvent[]

  @@index([category])
  @@index([brand])
  @@index([slug])
}

// ─── Oferta por tienda ────────────────────────────────────────────────────────
// Precio de un producto en una tienda concreta.
// Un producto → muchas ofertas (una por tienda).
model Offer {
  id              String   @id @default(cuid())
  productId       String
  store           String // ej: "Amazon", "MediaMarkt", "PcComponentes"
  priceCurrent    Float // precio actual en euros
  priceOld        Float? // precio anterior (para mostrar tachado)
  discountPercent Int? // % de descuento calculado
  externalUrl     String // enlace directo al producto en la tienda
  inStock         Boolean  @default(true)
  updatedAt       DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, store]) // un producto solo tiene una oferta por tienda
  @@index([productId])
  @@index([store])
  @@index([priceCurrent])
}

// ─── Historial de precios ─────────────────────────────────────────────────────
// Registro histórico de cada cambio de precio por producto y tienda.
// Permite mostrar "precio mínimo histórico" y gráficas de evolución.
model PriceHistory {
  id         String   @id @default(cuid())
  productId  String
  store      String
  price      Float
  recordedAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([productId, store])
  @@index([recordedAt])
}

// ─── Producto guardado ────────────────────────────────────────────────────────
model SavedProduct {
  id                    String    @id @default(cuid())
  userId                String
  productId             String
  savedAt               DateTime  @default(now())
  notifyOnDiscount      Boolean   @default(false)
  discountAlertSentAt   DateTime?
  savedPriceCurrent     Float?
  betterDealAlertSentAt DateTime?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([notifyOnDiscount])
}

// ─── Alerta de precio ─────────────────────────────────────────────────────────
model PriceAlert {
  id          String    @id @default(cuid())
  userId      String
  productId   String
  store       String
  targetPrice Float
  triggered   Boolean   @default(false)
  triggeredAt DateTime?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([productId])
}

// ─── Señal de Compra ──────────────────────────────────────────────────────────
model BuySignal {
  id        String @id @default(cuid())
  productId String
  store     String

  score Int // 0-100
  label String // "Compra ahora" | "Buen momento" | etc.

  priceScore Int // 0-40
  trendScore Int // 0-25
  storeScore Int // 0-20
  dealScore  Int // 0-15

  priceMin90d Float
  priceMax90d Float
  priceAvg90d Float
  trendSlope  Float // €/día
  isFakeDeal  Boolean

  calculatedAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, store])
  @@index([productId])
  @@index([score])
}

model StoreReputation {
  id               String   @id @default(cuid())
  store            String   @unique
  manipulationRate Float    @default(0)
  fakeDealCount    Int      @default(0)
  totalDeals       Int      @default(0)
  updatedAt        DateTime @updatedAt
}

// â”€â”€â”€ Comunidad â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

enum CommunityPostType {
  DISCUSION
  PREGUNTA
  CHOLLO
  CONSEJO
}

model CommunityPost {
  id        String            @id @default(cuid())
  userId    String
  productId String?
  title     String
  content   String            @db.Text
  type      CommunityPostType @default(DISCUSION)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  comments CommunityComment[]
  votes    CommunityVote[]

  @@index([type])
  @@index([createdAt])
}

model CommunityComment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  content   String   @db.Text
  createdAt DateTime @default(now())

  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([userId])
}

model CommunityVote {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  value     Int      @default(1)
  createdAt DateTime @default(now())

  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

// ─── Reseñas ─────────────────────────────────────────────────────────────────
model Review {
  id        String   @id @default(cuid())
  productId String
  userId    String
  rating    Int // 1-5
  title     String?
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([productId, userId])
  @@index([productId])
  @@index([userId])
}

// ═══════════════════════════════════════════════════════════════════════════
//  MÓDULO REPRICER (sellers B2B) — independiente del comparador B2C
// ═══════════════════════════════════════════════════════════════════════════

enum SellerPlan {
  TRIAL
  PRO
}

enum RepriceStrategy {
  BUYBOX // bajar por debajo del competidor más barato
  MATCH // igualar al competidor
  FIXED // precio fijo (ignora competencia)
  MARGIN // como BUYBOX pero con suelo de beneficio
  BUYBOX_WINNER // bajar por debajo del precio ACTUAL de la Buy Box
}

enum UndercutType {
  AMOUNT // restar importe fijo (ej. 0,01 €)
  PERCENT // restar porcentaje (ej. 2 %)
}

enum NoCompetitionMode {
  MAX // sin competencia → subir al máximo
  HOLD // sin competencia → mantener precio
  STEP_UP // sin competencia → subir gradualmente hacia el máximo
}

enum FulfillmentFilter {
  ANY // considerar todas las ofertas
  FBA // solo competidores con Logística de Amazon
  FBM // solo competidores que envían ellos mismos
}

enum BuyBoxStatus {
  UNKNOWN
  WON // tenemos la Buy Box
  LOST // la tiene otro vendedor
}

model SellerAccount {
  id             String @id @default(cuid())
  userId         String @unique
  amazonSellerId String @unique
  marketplaceId  String @default("A1RKKUPIHCS9HS")
  refreshToken   String @db.Text
  spApiEnv       String @default("sandbox")

  // ── Modo de operación ────────────────────────────────────────────────
  // "amazon": cuenta conectada vía SP-API (flujo histórico).
  // "manual": el vendedor no es de Amazon; gestiona su catálogo subiendo
  //   CSV y exporta planes de precios sugeridos. Para satisfacer el
  //   unique de `amazonSellerId` usamos un id sintético `manual_<cuid>`
  //   y `refreshToken` queda vacío.
  mode String @default("amazon")

  plan                 SellerPlan @default(TRIAL)
  trialEndsAt          DateTime?
  intervalSeconds      Int        @default(900)
  stripeCustomerId     String?    @unique
  stripeSubscriptionId String?    @unique

  active     Boolean   @default(true)
  lastSyncAt DateTime?
  lastRunAt  DateTime?
  lockedAt   DateTime? // lock de ciclo (evita solapamientos)

  // ── Estrategia por defecto de la cuenta (productos con useAccountDefaults) ──
  defaultStrategy      RepriceStrategy   @default(BUYBOX)
  defaultUndercutType  UndercutType      @default(AMOUNT)
  defaultUndercutValue Float             @default(0.01)
  defaultNoCompetition NoCompetitionMode @default(MAX)
  defaultStepUpType    UndercutType      @default(AMOUNT)
  defaultStepUpValue   Float             @default(0.05)

  // ── Programación horaria, simulación y throttling ──
  scheduleEnabled   Boolean @default(false)
  scheduleStartHour Int     @default(0) // hora local Europe/Madrid (0-23)
  scheduleEndHour   Int     @default(24) // exclusivo (24 = fin de día)
  dryRun            Boolean @default(false) // calcula pero NO aplica en Amazon
  patchDelayMs      Int     @default(0) // retardo entre PATCHes (anti QuotaExceeded)
  autoSyncHours     Int     @default(0) // sincroniza catálogo cada N h (0 = manual)

  // ── Anti-flapping (histéresis del motor) ──
  // No cambiar precio si el delta absoluto es menor que max(€, % del actual).
  // 0 = desactivado (compatibilidad con cuentas existentes).
  minChangeAmount Float @default(0) // umbral mínimo en €
  minChangePct    Float @default(0) // umbral mínimo en %
  // Debounce: segundos mínimos entre dos cambios consecutivos del MISMO signo
  // (dos bajadas o dos subidas seguidas). 0 = desactivado.
  debounceSeconds Int   @default(0)

  // ── Detector de guerra de precios ──
  // Ciclos seguidos bajando arrastrados por competencia que activan el freno.
  // 0 = OFF; valor típico 5.
  priceWarCycles Int    @default(0)
  // Acción al activar: "FLOOR" (saltar al suelo) | "PAUSE" (desactivar reprecio).
  priceWarAction String @default("FLOOR")

  // ── Aceleración del STEP_UP cuando estamos solos ──
  // Tras N ciclos sin competencia, el paso se duplica geométricamente hasta
  // stepUpMaxMult. 0 = OFF (compatible con comportamiento clásico).
  stepUpAccelCycles Int   @default(0)
  stepUpMaxMult     Float @default(8)

  // ── Alertas por email ──
  alertsEnabled     Boolean   @default(true)
  alertEmail        String? // destino (vacío = email de la cuenta)
  alertOnBuyBoxLost Boolean   @default(true) // avisar al perder la Buy Box
  alertOnPriceFloor Boolean   @default(true) // avisar al tocar el precio mínimo
  alertOnError      Boolean   @default(true) // avisar ante errores de reprecio
  lastAlertAt       DateTime? // cooldown anti-spam de correos
  trialReminderSent Boolean   @default(false) // aviso de fin de prueba enviado

  // ── Datos fiscales del cliente (para la factura) ──
  billingName    String @default("") // razón social / nombre fiscal
  billingTaxId   String @default("") // NIF / CIF / VAT
  billingAddress String @default("") // dirección fiscal
  billingCountry String @default("ES")

  // ── Seguridad: allowlist de IPs (CSV; vacío = sin restricción) ──
  ipAllowlist String @default("") @db.Text

  // ── Modo vacaciones: rango de pausa total ──
  vacationFrom DateTime?
  vacationTo   DateTime?
  vacationNote String    @default("")

  // ── Resumen semanal IA (cooldown) ──
  weeklyDigestSentAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  listings  SellerListing[]
  runs      RepricingRun[]
  auditLogs AuditLog[]

  @@index([active, lastRunAt])
}

model AuditLog {
  id              String   @id @default(cuid())
  sellerAccountId String
  action          String // clave: listing.strategy, account.settings…
  detail          String   @db.Text
  createdAt       DateTime @default(now())

  sellerAccount SellerAccount @relation(fields: [sellerAccountId], references: [id], onDelete: Cascade)

  @@index([sellerAccountId, createdAt])
}

model SellerListing {
  id              String @id @default(cuid())
  sellerAccountId String

  asin        String
  parentAsin  String  @default("") // ASIN padre (variación talla/color)
  sku         String
  title       String
  imageUrl    String?
  productType String? // SP-API productType (TELEVISION, etc), required for PATCH

  // "amazon" si vino del SP-API sync; "manual" si vino de un CSV (modo manual).
  source String @default("amazon")

  priceCurrent Float
  priceMin     Float?
  priceMax     Float?
  currency     String @default("EUR")

  repricingEnabled Boolean   @default(false)
  lastRepricedAt   DateTime?
  tags             String    @default("") // etiquetas/grupos, separadas por comas

  // ── Estrategia de reprecio ──
  strategy      RepriceStrategy   @default(BUYBOX)
  undercutType  UndercutType      @default(AMOUNT)
  undercutValue Float             @default(0.01)
  fixedPrice    Float? // estrategia FIXED
  cost          Float? // coste del producto (estrategia MARGIN)
  shippingCost  Float? // envío / logística propia por ud (€)
  fbaFee        Float? // tarifa fija FBA / gestión por ud (€)
  vatRate       Float?            @default(21) // % IVA del PVP (ES 21)
  feePercent    Float?            @default(15) // % comisión Amazon
  targetMargin  Float?            @default(10) // % margen objetivo (MARGIN)
  noCompetition NoCompetitionMode @default(MAX)
  stepUpType    UndercutType      @default(AMOUNT) // STEP_UP: paso € o %
  stepUpValue   Float             @default(0.05) // STEP_UP: tamaño del paso

  // ── Filtros de competencia ──
  useAccountDefaults Boolean           @default(false) // hereda estrategia de la cuenta
  ignoreAmazon       Boolean           @default(true) // ignorar al propio Amazon (retail)
  fulfillmentFilter  FulfillmentFilter @default(ANY)
  minSellerRating    Float? // ignorar vendedores por debajo (0-5)
  excludeSellers     String            @default("") // seller IDs a ignorar (lista negra)
  onlySellers        String            @default("") // si hay: solo estos (lista blanca)

  // ── Estado Buy Box ──
  buyBoxStatus BuyBoxStatus @default(UNKNOWN)
  buyBoxPrice  Float?
  buyBoxAt     DateTime?

  // ── Último estado de competencia (cache para UI y para detectar deltas) ──
  // priceWarStreak: ciclos consecutivos bajando arrastrados por competidor.
  // noCompetitionStreak: ciclos consecutivos sin competencia (para STEP_UP geométrico).
  // lastDirection: dirección del último cambio efectivo ("UP" | "DOWN"), para debounce.
  lastCompetitorPrice Float?
  lastCompetitorAt    DateTime?
  priceWarStreak      Int       @default(0)
  noCompetitionStreak Int       @default(0)
  lastDirection       String?

  // ── Resiliencia / sync inverso ──
  consecutiveErrors   Int       @default(0) // se incrementa en cada error, se resetea al primer éxito
  autoPausedAt        DateTime? // sello de pausado automático por errores
  autoPausedReason    String? // motivo legible del autopausa
  lastExpectedPrice   Float? // último precio que NOSOTROS aplicamos
  lastExpectedAt      DateTime? // cuándo lo aplicamos (para no comparar contra valores viejos)
  manualPriceDetected Boolean   @default(false) // se enciende al detectar cambio manual en Seller Central
  manualPriceAt       DateTime? // cuándo lo detectamos
  manualPriceBefore   Float? // precio que esperábamos
  manualPriceAfter    Float? // precio que encontramos

  // ── Plan de precios sugerido (modo manual) ──
  // Cache del último resultado de "Generar plan" para no recalcular cada vez
  // que el vendedor exporta CSV. Se invalida regenerando el plan.
  suggestedPrice      Float?
  suggestedAt         DateTime?
  suggestedConfidence Float? // 0-100
  suggestedStrategy   String? // free-form etiqueta del motor
  suggestedReason     String?   @db.Text // explicación breve

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sellerAccount SellerAccount      @relation(fields: [sellerAccountId], references: [id], onDelete: Cascade)
  events        RepricingEvent[]
  orderItems    RepriceOrderItem[]
  notes         ListingNote[]

  @@unique([sellerAccountId, sku])
  @@index([sellerAccountId, repricingEnabled])
}

// ─── Notas internas del equipo por listing ─────────────────────────────────
model ListingNote {
  id        String   @id @default(cuid())
  listingId String
  userId    String // autor
  content   String   @db.Text
  createdAt DateTime @default(now())

  listing SellerListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, createdAt])
}

// ─── Canales externos de notificación (Slack/Telegram/Discord/Webhook) ────
model NotificationChannel {
  id              String    @id @default(cuid())
  sellerAccountId String
  kind            String // "slack" | "telegram" | "discord" | "webhook"
  label           String    @default("Canal")
  webhookUrl      String    @db.Text
  // Para Telegram: chat_id (se concatena al URL en formato bot/sendMessage)
  extraTarget     String    @default("")
  enabled         Boolean   @default(true)
  alertBuyBoxLost Boolean   @default(true)
  alertPriceFloor Boolean   @default(true)
  alertError      Boolean   @default(true)
  alertAutoPause  Boolean   @default(true)
  alertWeekly     Boolean   @default(true)
  lastSentAt      DateTime?
  lastError       String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([sellerAccountId, enabled])
}

// ─── Cache de explicaciones IA por evento ──────────────────────────────────
// "Explica este cambio" genera narrativa una vez y la cachea: evita pagar
// repetidamente el mismo token y mantiene la respuesta determinista para
// el usuario aunque la BD se purgue.
model EventExplanation {
  id        String   @id @default(cuid())
  eventId   String   @unique
  narrative String   @db.Text
  source    String   @default("ai") // "ai" | "heuristic"
  tokensIn  Int      @default(0)
  tokensOut Int      @default(0)
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// ─── Vendedores marcados como "dumper" ──────────────────────────────────────
// El detector los identifica si nos baja el precio repetidamente. El usuario
// puede convertirlos en exclusión con un clic.
model DetectedDumper {
  id              String   @id @default(cuid())
  sellerAccountId String
  amazonSellerId  String // ID del vendedor que dumpea
  occurrences     Int      @default(1)
  lastDetectedAt  DateTime @default(now())
  acknowledged    Boolean  @default(false) // el usuario lo marcó como visto
  excluded        Boolean  @default(false) // ya lo añadió a la blacklist
  createdAt       DateTime @default(now())

  @@unique([sellerAccountId, amazonSellerId])
  @@index([sellerAccountId, acknowledged])
}

model RepricingRun {
  id              String    @id @default(cuid())
  sellerAccountId String
  startedAt       DateTime  @default(now())
  finishedAt      DateTime?

  listingsProcessed Int     @default(0)
  listingsRepriced  Int     @default(0)
  errors            Int     @default(0)
  errorMessage      String? @db.Text

  sellerAccount SellerAccount    @relation(fields: [sellerAccountId], references: [id], onDelete: Cascade)
  events        RepricingEvent[]

  @@index([sellerAccountId, startedAt])
}

model RepricingEvent {
  id        String @id @default(cuid())
  runId     String
  listingId String

  priceBefore     Float
  priceAfter      Float
  competitorPrice Float?
  reason          String
  success         Boolean      @default(true)
  simulated       Boolean      @default(false) // dry-run: calculado pero no aplicado
  buyBox          BuyBoxStatus @default(UNKNOWN) // estado Buy Box en ese ciclo
  errorMessage    String?      @db.Text

  createdAt DateTime @default(now())

  run     RepricingRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  listing SellerListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, createdAt])
  @@index([runId])
}

