// ─── Aprendizaje continuo del asistente ─────────────────────────────────────
// Registramos cada Q&A y el feedback del usuario. Un cron agrupa preguntas
// con baja confianza o feedback negativo y propone topics nuevos a aprobar.
model AssistantInteraction {
  id           String   @id @default(cuid())
  userId       String?
  question     String   @db.Text
  answer       String   @db.Text
  matchedKind  String   @default("none") // "static" | "learned" | "model" | "none"
  matchedKey   String?
  matchedScore Int      @default(0)
  helpful      Boolean?
  clusterId    String? // se setea cuando el motor de aprendizaje lo agrupa
  createdAt    DateTime @default(now())

  cluster AssistantLearnedTopic? @relation(fields: [clusterId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([matchedKind, helpful])
  @@index([clusterId])
}

// Topic aprendido automáticamente (candidato) o aprobado manualmente.
// Cuando approved=true entra al runtime del asistente y refuerza por uso.
model AssistantLearnedTopic {
  id             String    @id @default(cuid())
  keywords       String    @db.Text // separadas por coma (normalizadas, sin acentos)
  sampleQuestion String    @db.Text // pregunta representativa del cluster
  answer         String    @db.Text
  followUps      String    @default("") // "preg1|preg2|preg3"
  source         String    @default("auto") // "auto" | "manual"
  approved       Boolean   @default(false)
  approvedAt     DateTime?
  usageCount     Int       @default(0)
  helpfulCount   Int       @default(0)
  unhelpfulCount Int       @default(0)
  occurrences    Int       @default(1) // cuántas preguntas se agruparon aquí
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  interactions AssistantInteraction[]

  @@index([approved, helpfulCount])
  @@index([createdAt])
}

// ─── Resiliencia del motor: quota tracker ──────────────────────────────────
// Una fila por cuenta y día. Incrementamos PATCHes y errores en cada ciclo
// para mostrar al usuario "1.243 de 100k PATCHes hoy" y detectar abusos.
model RepriceQuotaUsage {
  id               String   @id @default(cuid())
  sellerAccountId  String
  day              DateTime @db.Date
  patchCount       Int      @default(0)
  patchRetries     Int      @default(0)
  errorCount       Int      @default(0)
  rateLimitedCount Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([sellerAccountId, day])
  @@index([sellerAccountId, day])
}

// ─── Pedidos reales (SP-API Orders) ─────────────────────────────────────────
// Sync periódico desde Amazon. Alimenta velocidad de venta, gráficas de
// ventas, heatmap horario y el pricing engine con confianza alta.
model RepriceOrder {
  id              String   @id @default(cuid())
  sellerAccountId String
  amazonOrderId   String // ej: 123-1234567-1234567
  purchaseDate    DateTime
  orderStatus     String // Pending|Unshipped|Shipped|Canceled|...
  totalAmount     Float? // bruto en divisa local
  currency        String   @default("EUR")
  marketplaceId   String   @default("A1RKKUPIHCS9HS")
  buyerEmail      String? // hash o pseudonimizado
  fulfillment     String? // AFN (FBA) | MFN (FBM)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  items RepriceOrderItem[]

  @@unique([sellerAccountId, amazonOrderId])
  @@index([sellerAccountId, purchaseDate])
}

model RepriceOrderItem {
  id        String   @id @default(cuid())
  orderId   String
  listingId String? // join con SellerListing por SKU si existe
  asin      String
  sku       String
  title     String
  quantity  Int      @default(1)
  unitPrice Float? // precio unitario neto si está disponible
  itemPrice Float? // total línea bruto
  createdAt DateTime @default(now())

  order   RepriceOrder   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  listing SellerListing? @relation(fields: [listingId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([listingId, createdAt])
  @@index([asin])
  @@index([sku])
}

// ─── Tracking de clicks de afiliación ─────────────────────────────────────────
// Registra cada salida del usuario hacia la tienda. La conversión llegará
// luego por postback del afiliado (Awin, etc.) — esta tabla cubre solo
// el evento de click. retailerPosition empieza en 0 (0=primaria).
model AffiliateClickEvent {
  id               String   @id @default(cuid())
  productId        String
  userId           String?
  selectedRetailer String
  retailerPosition Int
  isPrimary        Boolean  @default(false)
  pageContext      String?
  placement        String?
  clickedAt        DateTime @default(now())

  product     Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  user        User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  conversions AffiliateConversion[]

  @@index([productId, clickedAt])
  @@index([selectedRetailer, clickedAt])
  @@index([userId, clickedAt])
}

// ─── Conversión de afiliación (postback Awin u otra red) ──────────────────────
// Llega por server-to-server. transactionId del proveedor es único para
// idempotencia (Awin reenvía postbacks ante cambios de estado: pending →
// approved/rejected). Cuando el click se etiquetó con &clickref={id}, el
// proveedor lo devuelve y enlazamos con AffiliateClickEvent.
enum AffiliateConversionStatus {
  PENDING
  APPROVED
  REJECTED
}

model AffiliateConversion {
  id            String                    @id @default(cuid())
  network       String // "awin", "tradedoubler", etc.
  transactionId String // id del proveedor (único por red)
  store         String // merchant name / id
  amount        Float // total de la venta en €
  commission    Float // comisión bruta en €
  currency      String                    @default("EUR")
  status        AffiliateConversionStatus @default(PENDING)
  clickEventId  String? // si vino clickref
  rawPayload    Json // postback original (auditoría)
  receivedAt    DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  clickEvent AffiliateClickEvent? @relation(fields: [clickEventId], references: [id], onDelete: SetNull)

  @@unique([network, transactionId])
  @@index([store, receivedAt])
  @@index([status])
  @@index([clickEventId])
}
