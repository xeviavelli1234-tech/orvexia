generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                       String    @id @default(cuid())
  name                     String
  email                    String    @unique
  password                 String?
  googleId                 String?   @unique
  emailVerified            Boolean   @default(false)
  verificationToken        String?   @unique
  verificationTokenExpires DateTime?
  resetPasswordToken       String?   @unique
  resetPasswordExpires     DateTime?
  avatarColor              String    @default("#2563EB")
  avatarEmoji              String?
  avatarUrl                String?   @db.Text
  bio                      String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  savedProducts SavedProduct[]
  priceAlerts   PriceAlert[]
  communityPosts    CommunityPost[]
  communityComments CommunityComment[]
  communityVotes    CommunityVote[]
  reviews           Review[]
  sellerAccount     SellerAccount?
}

// ─── Categorías disponibles ───────────────────────────────────────────────────
enum Category {
  TELEVISORES
  LAVADORAS
  FRIGORIFICOS
  LAVAVAJILLAS
  SECADORAS
  HORNOS
  MICROONDAS
  ASPIRADORAS
  CAFETERAS
  AIRES_ACONDICIONADOS
  OTROS
}

// ─── Producto ─────────────────────────────────────────────────────────────────
// Representa un electrodoméstico genérico (independiente de tienda o precio).
// Un mismo producto puede tener ofertas en varias tiendas.
model Product {
  id          String    @id @default(cuid())
  slug        String    @unique           // ej: "samsung-galaxy-qled-55-2024"
  name        String                      // ej: "Samsung QLED 55\" 4K Q80C"
  category    Category
  brand       String                      // ej: "Samsung"
  model       String                      // ej: "QE55Q80CATXXC"
  image       String?                     // URL de imagen principal
  images      String[]                    // galería de imágenes
  description String?
  rating      Float?                      // ej: 4.4
  reviewCount Int?                        // ej: 4471
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  offers        Offer[]
  priceHistory  PriceHistory[]
  buySignals    BuySignal[]
  savedBy       SavedProduct[]
  priceAlerts   PriceAlert[]
  communityPosts CommunityPost[]
  reviews       Review[]

  @@index([category])
  @@index([brand])
  @@index([slug])
}

// ─── Oferta por tienda ────────────────────────────────────────────────────────
// Precio de un producto en una tienda concreta.
// Un producto → muchas ofertas (una por tienda).
model Offer {
  id              String   @id @default(cuid())
  productId       String
  store           String                   // ej: "Amazon", "MediaMarkt", "PcComponentes"
  priceCurrent    Float                    // precio actual en euros
  priceOld        Float?                   // precio anterior (para mostrar tachado)
  discountPercent Int?                     // % de descuento calculado
  externalUrl     String                   // enlace directo al producto en la tienda
  inStock         Boolean  @default(true)
  updatedAt       DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, store])             // un producto solo tiene una oferta por tienda
  @@index([productId])
  @@index([store])
  @@index([priceCurrent])
}

// ─── Historial de precios ─────────────────────────────────────────────────────
// Registro histórico de cada cambio de precio por producto y tienda.
// Permite mostrar "precio mínimo histórico" y gráficas de evolución.
model PriceHistory {
  id        String   @id @default(cuid())
  productId String
  store     String
  price     Float
  recordedAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([productId, store])
  @@index([recordedAt])
}

// ─── Producto guardado ────────────────────────────────────────────────────────
model SavedProduct {
  id        String   @id @default(cuid())
  userId    String
  productId String
  savedAt   DateTime @default(now())
  notifyOnDiscount    Boolean   @default(false)
  discountAlertSentAt DateTime?
  savedPriceCurrent   Float?
  betterDealAlertSentAt DateTime?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([notifyOnDiscount])
}

// ─── Alerta de precio ─────────────────────────────────────────────────────────
model PriceAlert {
  id          String    @id @default(cuid())
  userId      String
  productId   String
  store       String
  targetPrice Float
  triggered   Boolean   @default(false)
  triggeredAt DateTime?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([productId])
}

// ─── Señal de Compra ──────────────────────────────────────────────────────────
model BuySignal {
  id           String   @id @default(cuid())
  productId    String
  store        String

  score        Int      // 0-100
  label        String   // "Compra ahora" | "Buen momento" | etc.

  priceScore   Int      // 0-40
  trendScore   Int      // 0-25
  storeScore   Int      // 0-20
  dealScore    Int      // 0-15

  priceMin90d  Float
  priceMax90d  Float
  priceAvg90d  Float
  trendSlope   Float    // €/día
  isFakeDeal   Boolean

  calculatedAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, store])
  @@index([productId])
  @@index([score])
}

model StoreReputation {
  id               String   @id @default(cuid())
  store            String   @unique
  manipulationRate Float    @default(0)
  fakeDealCount    Int      @default(0)
  totalDeals       Int      @default(0)
  updatedAt        DateTime @updatedAt
}

// â”€â”€â”€ Comunidad â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

enum CommunityPostType {
  DISCUSION
  PREGUNTA
  CHOLLO
  CONSEJO
}

model CommunityPost {
  id        String            @id @default(cuid())
  userId    String
  productId String?
  title     String
  content   String            @db.Text
  type      CommunityPostType @default(DISCUSION)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  comments CommunityComment[]
  votes    CommunityVote[]

  @@index([type])
  @@index([createdAt])
}

model CommunityComment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  content   String   @db.Text
  createdAt DateTime @default(now())

  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([userId])
}

model CommunityVote {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  value     Int      @default(1)
  createdAt DateTime @default(now())

  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

// ─── Reseñas ─────────────────────────────────────────────────────────────────
model Review {
  id        String   @id @default(cuid())
  productId String
  userId    String
  rating    Int      // 1-5
  title     String?
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([productId, userId])
  @@index([productId])
  @@index([userId])
}

// ═══════════════════════════════════════════════════════════════════════════
//  MÓDULO REPRICER (sellers B2B) — independiente del comparador B2C
// ═══════════════════════════════════════════════════════════════════════════

enum SellerPlan {
  TRIAL
  PRO
}

enum RepriceStrategy {
  BUYBOX // bajar por debajo del competidor más barato
  MATCH // igualar al competidor
  FIXED // precio fijo (ignora competencia)
  MARGIN // como BUYBOX pero con suelo de beneficio
}

enum UndercutType {
  AMOUNT // restar importe fijo (ej. 0,01 €)
  PERCENT // restar porcentaje (ej. 2 %)
}

enum NoCompetitionMode {
  MAX // sin competencia → subir al máximo
  HOLD // sin competencia → mantener precio
}

model SellerAccount {
  id              String     @id @default(cuid())
  userId          String     @unique
  amazonSellerId  String     @unique
  marketplaceId   String     @default("A1RKKUPIHCS9HS")
  refreshToken    String     @db.Text
  spApiEnv        String     @default("sandbox")

  plan                 SellerPlan @default(TRIAL)
  trialEndsAt          DateTime?
  intervalSeconds      Int        @default(900)
  stripeCustomerId     String?    @unique
  stripeSubscriptionId String?    @unique

  active          Boolean    @default(true)
  lastSyncAt      DateTime?
  lastRunAt       DateTime?

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  listings SellerListing[]
  runs     RepricingRun[]

  @@index([active, lastRunAt])
}

model SellerListing {
  id              String   @id @default(cuid())
  sellerAccountId String

  asin            String
  sku             String
  title           String
  imageUrl        String?
  productType     String?                            // SP-API productType (TELEVISION, etc), required for PATCH

  priceCurrent    Float
  priceMin        Float?
  priceMax        Float?
  currency        String   @default("EUR")

  repricingEnabled Boolean  @default(false)
  lastRepricedAt   DateTime?

  // ── Estrategia de reprecio ──
  strategy      RepriceStrategy   @default(BUYBOX)
  undercutType  UndercutType      @default(AMOUNT)
  undercutValue Float             @default(0.01)
  fixedPrice    Float?            // estrategia FIXED
  cost          Float?            // coste del producto (estrategia MARGIN)
  feePercent    Float?            @default(15) // % comisión Amazon
  targetMargin  Float?            @default(10) // % margen objetivo (MARGIN)
  noCompetition NoCompetitionMode @default(MAX)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  sellerAccount SellerAccount    @relation(fields: [sellerAccountId], references: [id], onDelete: Cascade)
  events        RepricingEvent[]

  @@unique([sellerAccountId, sku])
  @@index([sellerAccountId, repricingEnabled])
}

model RepricingRun {
  id              String    @id @default(cuid())
  sellerAccountId String
  startedAt       DateTime  @default(now())
  finishedAt      DateTime?

  listingsProcessed Int     @default(0)
  listingsRepriced  Int     @default(0)
  errors            Int     @default(0)
  errorMessage      String? @db.Text

  sellerAccount SellerAccount    @relation(fields: [sellerAccountId], references: [id], onDelete: Cascade)
  events        RepricingEvent[]

  @@index([sellerAccountId, startedAt])
}

model RepricingEvent {
  id              String   @id @default(cuid())
  runId           String
  listingId       String

  priceBefore     Float
  priceAfter      Float
  competitorPrice Float?
  reason          String
  success         Boolean  @default(true)
  errorMessage    String?  @db.Text

  createdAt       DateTime @default(now())

  run     RepricingRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  listing SellerListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, createdAt])
  @@index([runId])
}

