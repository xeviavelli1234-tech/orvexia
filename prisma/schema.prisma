generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                       String    @id @default(cuid())
  name                     String
  email                    String    @unique
  password                 String?
  googleId                 String?   @unique
  emailVerified            Boolean   @default(false)
  verificationToken        String?   @unique
  verificationTokenExpires DateTime?
  resetPasswordToken       String?   @unique
  resetPasswordExpires     DateTime?
  avatarColor              String    @default("#2563EB")
  avatarEmoji              String?
  avatarUrl                String?   @db.Text
  bio                      String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  savedProducts SavedProduct[]
  priceAlerts   PriceAlert[]
  communityPosts    CommunityPost[]
  communityComments CommunityComment[]
  communityVotes    CommunityVote[]
  reviews           Review[]
}

// ─── Categorías disponibles ───────────────────────────────────────────────────
enum Category {
  TELEVISORES
  LAVADORAS
  FRIGORIFICOS
  LAVAVAJILLAS
  SECADORAS
  HORNOS
  MICROONDAS
  ASPIRADORAS
  CAFETERAS
  AIRES_ACONDICIONADOS
  OTROS
}

// ─── Producto ─────────────────────────────────────────────────────────────────
// Representa un electrodoméstico genérico (independiente de tienda o precio).
// Un mismo producto puede tener ofertas en varias tiendas.
model Product {
  id          String    @id @default(cuid())
  slug        String    @unique           // ej: "samsung-galaxy-qled-55-2024"
  name        String                      // ej: "Samsung QLED 55\" 4K Q80C"
  category    Category
  brand       String                      // ej: "Samsung"
  model       String                      // ej: "QE55Q80CATXXC"
  image       String?                     // URL de imagen principal
  images      String[]                    // galería de imágenes
  description String?
  rating      Float?                      // ej: 4.4
  reviewCount Int?                        // ej: 4471
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  offers        Offer[]
  priceHistory  PriceHistory[]
  buySignals    BuySignal[]
  savedBy       SavedProduct[]
  priceAlerts   PriceAlert[]
  communityPosts CommunityPost[]
  reviews       Review[]

  @@index([category])
  @@index([brand])
  @@index([slug])
}

// ─── Oferta por tienda ────────────────────────────────────────────────────────
// Precio de un producto en una tienda concreta.
// Un producto → muchas ofertas (una por tienda).
model Offer {
  id              String   @id @default(cuid())
  productId       String
  store           String                   // ej: "Amazon", "MediaMarkt", "PcComponentes"
  priceCurrent    Float                    // precio actual en euros
  priceOld        Float?                   // precio anterior (para mostrar tachado)
  discountPercent Int?                     // % de descuento calculado
  externalUrl     String                   // enlace directo al producto en la tienda
  inStock         Boolean  @default(true)
  updatedAt       DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, store])             // un producto solo tiene una oferta por tienda
  @@index([productId])
  @@index([store])
  @@index([priceCurrent])
}

// ─── Historial de precios ─────────────────────────────────────────────────────
// Registro histórico de cada cambio de precio por producto y tienda.
// Permite mostrar "precio mínimo histórico" y gráficas de evolución.
model PriceHistory {
  id        String   @id @default(cuid())
  productId String
  store     String
  price     Float
  recordedAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([productId, store])
  @@index([recordedAt])
}

// ─── Producto guardado ────────────────────────────────────────────────────────
model SavedProduct {
  id        String   @id @default(cuid())
  userId    String
  productId String
  savedAt   DateTime @default(now())
  notifyOnDiscount    Boolean   @default(false)
  discountAlertSentAt DateTime?
  savedPriceCurrent   Float?
  betterDealAlertSentAt DateTime?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([notifyOnDiscount])
}

// ─── Alerta de precio ─────────────────────────────────────────────────────────
model PriceAlert {
  id          String    @id @default(cuid())
  userId      String
  productId   String
  store       String
  targetPrice Float
  triggered   Boolean   @default(false)
  triggeredAt DateTime?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([productId])
}

// ─── Señal de Compra ──────────────────────────────────────────────────────────
model BuySignal {
  id           String   @id @default(cuid())
  productId    String
  store        String

  score        Int      // 0-100
  label        String   // "Compra ahora" | "Buen momento" | etc.

  priceScore   Int      // 0-40
  trendScore   Int      // 0-25
  storeScore   Int      // 0-20
  dealScore    Int      // 0-15

  priceMin90d  Float
  priceMax90d  Float
  priceAvg90d  Float
  trendSlope   Float    // €/día
  isFakeDeal   Boolean

  calculatedAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, store])
  @@index([productId])
  @@index([score])
}

model StoreReputation {
  id               String   @id @default(cuid())
  store            String   @unique
  manipulationRate Float    @default(0)
  fakeDealCount    Int      @default(0)
  totalDeals       Int      @default(0)
  updatedAt        DateTime @updatedAt
}

